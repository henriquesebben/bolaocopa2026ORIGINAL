# Copie este arquivo para ".env" e preencha os valores.
# NUNCA suba o arquivo ".env" para o repositório!

# String de conexão com o PostgreSQL (Supabase, Render, etc.)
# Formato: postgresql://usuario:senha@host:porta/nome_banco
DATABASE_URL=postgresql://usuario:senha@host:5432/bolao

# Chave secreta para assinar os tokens JWT.
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte

# Nome e senha do usuário admin (criado automaticamente na primeira execução)
ADMIN_NOME=Henrique Sebben
ADMIN_SENHA=copa2026

# ── Sync automático de resultados (API-Football via RapidAPI) ─────────────────
# Cadastre-se em: https://rapidapi.com/api-sports/api/api-football
# Cole aqui a sua chave de API:
RAPIDAPI_KEY=sua-chave-aqui

# ID da liga Copa do Mundo 2026 na API-Football.
# Para descobrir: acesse https://api-football-v1.p.rapidapi.com/v3/leagues?name=world+cup&season=2026
# e copie o valor de "league.id"
WC2026_LEAGUE_ID=1

# Intervalo (em minutos) entre sincronizações durante janelas de jogo.
# 30 minutos = reduz o uso da API gratuita e ainda consegue atualizar resultados em tempo razoável.
# 60 minutos = mais econômico, mas as atualizações podem ficar mais lentas.
SYNC_INTERVAL_MINS=30
